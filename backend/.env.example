# Environment Configuration (EXAMPLE - Copy this to .env and fill in your values)
NODE_ENV=development

# Server Configuration
PORT=5000
HOST=localhost

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=7d

# Database Configuration
# Current backend storage is still file-based, but keep the MongoDB connection string here for the upcoming DB migration.
MONGODB_URI=mongodb+srv://aditya_chit:aditya@cluster0.7xsgsfx.mongodb.net/
MONGODB_DB_NAME=mergeconflicts
DATABASE_PATH=../data/song-db.json
USER_DATABASE_PATH=../data/user-db.json

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,ogg,aac,m4a

# Feature Extraction Configuration
WAVEFORM_WINDOW_SIZE=2048
SPECTRAL_BINS=512
SPECTRAL_BANDS=16
NUM_ANCHOR_POINTS=5

# API Documentation
API_TITLE=Audio Identification System
API_VERSION=1.0.0
API_DESCRIPTION=Audio fingerprinting and matching system with authentication

# Logging
LOG_LEVEL=info
ENABLE_DEBUG_LOGS=false

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
